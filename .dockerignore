# ============================================================
# .dockerignore
# Fichiers exclus du contexte Docker (build plus rapide)
# ============================================================

# Git
.git
.gitignore
.gitattributes

# Node
node_modules

# Laravel
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php

# Environnement local (IMPORTANT : ne jamais inclure le .env local)
.env
.env.backup
.env.local
.env.*.local

# Tests
tests
phpunit.xml
pest.xml

# Documentation et outils dev
README.md
CHANGELOG.md
docker-compose.yml
*.md

# IDE
.idea
.vscode
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

# Build artifacts non nécessaires
/public/hot
/public/storage
